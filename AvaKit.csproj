<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>

    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- =========================
         NUGET CONFIG
    ========================== -->
    <PackageId>AvaKit</PackageId>
    <Version>1.0.0</Version>
    <Authors>YourName</Authors>
    <Description>Avalonia UI Component Library (Input, Search, etc)</Description>
    <PackageTags>avalonia;ui;components;input;search</PackageTags>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeBuildOutput>true</IncludeBuildOutput>

    <!-- penting untuk library UI -->
    <IsPackable>true</IsPackable>

    <!-- optional tapi bagus -->
    <RepositoryUrl>https://github.com/fidartechstudio/AvaKit</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.1" />
    <PackageReference Include="Material.Icons.Avalonia" Version="3.0.2" />
  </ItemGroup>

</Project>