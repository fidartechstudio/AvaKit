<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="AvaKit.Controls.Input.InputComponent"
             x:Name="Root">
    <UserControl.Styles>
        <!-- Style dasar TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>
        <Style Selector="TextBox:disabled">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#999999"/>
        </Style>
        <!-- Style untuk TextBox dengan kelas error -->
        <Style Selector="TextBox.error">
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox.error:focus">
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <!-- Style TextBlock label -->
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="TextBlock.error-message">
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <!-- Style button mata -->
        <Style Selector="Button.EyeButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.EyeButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.EyeButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="0,6,0,6">
        <TextBlock Text="{Binding Label, ElementName=Root}" 
                   IsVisible="{Binding Label, ElementName=Root, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <Grid>
            <TextBox x:Name="InputTextBox"
                     Text="{Binding Value, Mode=TwoWay, ElementName=Root}"
                     PlaceholderText="{Binding Placeholder, ElementName=Root}"
                     IsEnabled="{Binding IsInputEnabled, ElementName=Root}"
                     UseFloatingPlaceholder="False"
                     Padding="12,0,40,0"
                     VerticalContentAlignment="Center"/>
            <Button x:Name="PasswordToggleButton"
                    HorizontalAlignment="Right"
                    Width="40"
                    Classes="EyeButton"
                    Click="OnTogglePasswordClick"
                    IsVisible="{Binding IsPassword, ElementName=Root}"
                    VerticalAlignment="Center">
                <materialIcons:MaterialIcon x:Name="ToggleIcon" 
                                            Kind="Eye" 
                                            Foreground="#888888" 
                                            Width="20" 
                                            Height="20"/>
            </Button>
        </Grid>
        <TextBlock Text="{Binding ErrorText, ElementName=Root}" 
                   Classes="error-message"
                   IsVisible="{Binding HasError, ElementName=Root}"/>
    </StackPanel>
</UserControl>